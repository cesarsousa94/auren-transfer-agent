[Unit]
Description=Auren Transfer Agent
Documentation=file:/usr/share/doc/auren-transfer-agent/linux-package-bootstrap.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=auren-agent
Group=auren-agent
EnvironmentFile=-/etc/auren-transfer-agent/auren-transfer-agent.env
ExecStart=/usr/bin/auren-transfer-agent serve --config /etc/auren-transfer-agent/agent.yaml
WorkingDirectory=/var/lib/auren-transfer-agent
Restart=always
RestartSec=5s
TimeoutStopSec=45s
KillSignal=SIGTERM
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/auren-transfer-agent /var/log/auren-transfer-agent /var/tmp/auren-transfer-agent

[Install]
WantedBy=multi-user.target
