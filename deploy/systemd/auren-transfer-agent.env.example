AUREN_RUNTIME_ENVIRONMENT=production
AUREN_LOGGER_FORMAT=json
AUREN_SERVER_ENABLED=true
AUREN_SERVER_HOST=0.0.0.0
AUREN_SERVER_PORT=8080
AUREN_RUNTIME_DATA_DIR=/var/lib/auren-transfer-agent
AUREN_RUNTIME_TEMP_DIR=/var/tmp/auren-transfer-agent
AUREN_DOWNLOAD_TEMP_DIR=/var/tmp/auren-transfer-agent/downloads
AUREN_STORAGE_DRIVER=local
AUREN_STORAGE_LOCAL_PATH=/var/lib/auren-transfer-agent/storage
AUREN_STORAGE_ENDPOINT=
AUREN_STORAGE_BUCKET=
AUREN_STORAGE_ACCESS_KEY_ID=
AUREN_STORAGE_SECRET_ACCESS_KEY=
AUREN_STORAGE_SESSION_TOKEN=
AUREN_STORAGE_S3_FORCE_PATH_STYLE=false
AUREN_SECURITY_API_KEY_REQUIRED=false
AUREN_SECURITY_API_KEY=
AUREN_MEDIA_HUB_ENABLED=true
AUREN_MEDIA_HUB_BASE_URL=
AUREN_MEDIA_HUB_REGISTRATION_TOKEN=
AUREN_MEDIA_HUB_BOOTSTRAP_TOKEN_ENDPOINT=
AUREN_MEDIA_HUB_BOOTSTRAP_TOKEN_SECRET=
AUREN_MEDIA_HUB_REGISTER_PATH=/api/internal/nodes/register
AUREN_MEDIA_HUB_CONFIG_PATH=/api/internal/nodes/config
AUREN_MEDIA_HUB_HEARTBEAT_PATH=/api/internal/nodes/heartbeat
AUREN_MEDIA_HUB_METRICS_PATH=/api/internal/nodes/metrics
AUREN_MEDIA_HUB_EVENTS_PATH=/api/internal/nodes/events
AUREN_MEDIA_HUB_NODE_UUID=
AUREN_MEDIA_HUB_NODE_SECRET=
AUREN_MEDIA_HUB_HMAC_ENABLED=true
AUREN_MEDIA_HUB_POLL_ENABLED=true
AUREN_MEDIA_HUB_TRANSFER_ENABLED=true
AUREN_MEDIA_HUB_CLAIM_ENABLED=true
AUREN_MEDIA_HUB_CLAIM_INTERVAL=2s
AUREN_MEDIA_HUB_PROGRESS_INTERVAL=5s
AUREN_MEDIA_HUB_CONTROL_INTERVAL=10s
AUREN_MEDIA_HUB_MAX_CONCURRENT_JOBS=2
AUREN_MEDIA_HUB_ACCEPTED_OPERATIONS=media_remote_download,playlist_m3u_download,remote_download
AUREN_MEDIA_HUB_WORK_DIR=/var/lib/auren-transfer-agent/transfer
AUREN_MEDIA_HUB_GATEWAY_ENABLED=false
AUREN_MEDIA_HUB_GATEWAY_PROXY_ENABLED=true
AUREN_MEDIA_HUB_GATEWAY_REDIRECT_ENABLED=true
AUREN_MEDIA_HUB_DRAIN_ENABLED=true
AUREN_MEDIA_HUB_DRAIN_FILE=/var/lib/auren-transfer-agent/transfer/drain
AUREN_MEDIA_HUB_BACKPRESSURE_ENABLED=true
AUREN_MEDIA_HUB_DISK_GUARD_ENABLED=true
AUREN_MEDIA_HUB_DISK_MIN_FREE_BYTES=1073741824
AUREN_MEDIA_HUB_DEAD_LETTER_ENABLED=true
AUREN_MEDIA_HUB_DEAD_LETTER_DIR=/var/lib/auren-transfer-agent/transfer/dead-letter
AUREN_MEDIA_HUB_LEASE_RENEWAL_ENABLED=true
AUREN_MEDIA_HUB_LEASE_RENEWAL_INTERVAL=30s
AUREN_MEDIA_HUB_ROLE=hybrid
AUREN_MEDIA_HUB_PROVIDER=auren_transfer_agent
AUREN_MEDIA_HUB_REGION=sa-east-1
AUREN_MEDIA_HUB_PUBLIC_BASE_URL=
AUREN_MEDIA_HUB_HEALTH_URL=
AUREN_MEDIA_HUB_MAX_SESSIONS=500
AUREN_MEDIA_HUB_MAX_EGRESS_MBPS=1000
AUREN_MEDIA_HUB_CAPABILITIES=transfer,download,upload,auren_storage,xtream,shui,m3u8,hls

AUREN_DEV_UI_ENABLED=true
AUREN_DEV_UI_PATH=/_auren/dev
AUREN_DEV_UI_CAPTURE_BODIES=true
AUREN_DEV_UI_BODY_LIMIT_BYTES=8192
